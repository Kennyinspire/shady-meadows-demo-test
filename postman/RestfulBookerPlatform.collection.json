{
  "info": {
    "name": "Restful Booker Platform — QA Exercise",
    "_postman_id": "bb-demo-qa-exercise",
    "description": "API test collection for the Restful Booker Platform. Covers authentication, booking CRUD, and availability scenarios from the QA Technical Exercise.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://automationintesting.online",
      "type": "string"
    },
    {
      "key": "adminUsername",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "password",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "bookingId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "TC-11 — POST /auth/login — valid credentials return token within 5s",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token is present in response', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('authToken', body.token);",
                  "});",
                  "pm.test('Response time is under 5000ms (AC: auth within 5s)', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          }
        },
        {
          "name": "TC-12 — POST /auth/login — invalid password returns 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('No token is issued', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"wrongpassword123\"\n}"
            }
          }
        },
        {
          "name": "TC-13 — POST /auth/login — invalid username returns 403, generic error",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Response body does not reveal which field failed (no username enumeration)', () => {",
                  "  const body = JSON.stringify(pm.response.json()).toLowerCase();",
                  "  pm.expect(body).to.not.include('username not found');",
                  "  pm.expect(body).to.not.include('user does not exist');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"notarealuser\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          }
        },
        {
          "name": "TC-14a — POST /auth/validate — valid token returns 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 for a valid token', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/validate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "validate"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{authToken}}\"\n}"
            }
          }
        },
        {
          "name": "TC-14b — POST /auth/validate — invalid token returns 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403 for an invalid token', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/validate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "validate"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"invalid-token-xyz\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "TC-08 — GET /api/booking — filter by date returns correct bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains rooms array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.rooms).to.be.an('array');",
                  "});",
                  "pm.test('Response time is acceptable', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/room?checkin=2026-08-01&checkout=2026-08-05",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "room"
              ],
              "query": [
                {
                  "key": "checkin",
                  "value": "2026-08-01"
                },
                {
                  "key": "checkout",
                  "value": "2026-08-05"
                }
              ]
            }
          }
        },
        {
          "name": "Setup — POST /api/booking — create test booking (stores bookingId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 400', () => pm.expect([200, 400]).to.include(pm.response.code));",
                  "const body = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('bookingId', body.bookingid);",
                  "  pm.test('Booking ID is returned', () => {",
                  "    pm.expect(body.bookingid).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/booking/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "booking",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"AUTOTEST\",\n  \"lastname\": \"Newman\",\n  \"totalprice\": 100,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-09-01\",\n    \"checkout\": \"2026-09-03\"\n  },\n  \"additionalneeds\": \"QA automation test booking\"\n}"
            }
          }
        },
        {
          "name": "TC-17 — DELETE /api/booking/:id — unauthenticated returns 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403, 404, or 405', () => pm.expect([403, 404, 405]).to.include(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/booking/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "booking",
                "{{bookingId}}"
              ]
            }
          }
        },
        {
          "name": "Teardown — DELETE /api/booking/:id — authenticated (cleanup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Booking deleted (201) or already gone (404) or invalid method (405)', () => {",
                  "  pm.expect([201, 200, 404, 405]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/booking/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "booking",
                "{{bookingId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "GET /api/auth/actuator/health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Auth service is healthy', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "GET /api/booking/actuator/health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Booking service is healthy', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/booking/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "booking",
                "actuator",
                "health"
              ]
            }
          }
        }
      ]
    }
  ]
}